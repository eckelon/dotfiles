call plug#begin('~/.local/share/nvim/plugged')

" git
Plug 'tpope/vim-fugitive' "A Git wrapper so awesome, it should be illegal
Plug 'airblade/vim-gitgutter' "shows a git diff in the gutter (sign column) and stages/undoes hunks

" gui
Plug 'Yggdroot/indentLine' "highlighting 4sp indenting
Plug 'ap/vim-css-color', { 'for': ['scss', 'css'] } "Preview colours in source code while editing
Plug 'itchyny/lightline.vim' "A light and configurable statusline/tabline plugin for Vim
Plug 'arcticicestudio/nord-vim' "An arctic, north-bluish clean and elegant Vim theme.
Plug 'kaicataldo/material.vim' "A port of the Material color scheme for Vim/Neovim

"programming
Plug 'nestorsalceda/vim-strip-trailing-whitespaces'
Plug 'honza/vim-snippets'
Plug 'tpope/vim-commentary' "comment stuff out
Plug 'editorconfig/editorconfig-vim' "editorconfig support
Plug 'alvan/vim-closetag', { 'for': ['html', 'xml'] }
Plug 'elzr/vim-json', { 'for': 'json'}
Plug '~/.vim/npm-test-plugin', { 'for': 'javascript' }
Plug '~/.vim/json-format-plugin', { 'for': 'json' }
Plug 'ludovicchabant/vim-gutentags', { 'for': ['javascript', 'vue', 'svelte', 'typescript', 'scala']}
" Plug 'jiangmiao/auto-pairs', {'for': ['javascript', 'vimscript']}
Plug 'ruanyl/vim-fixmyjs' "auto fix your javascript using fixmyjs/eslint/tslint/jscs
" Plug 'posva/vim-vue' "vue hightlight
Plug 'storyn26383/vim-vue' "Vim syntax highlighting for Vue components.
Plug 'derekwyatt/vim-scala', {'for': ['scala', 'sbt']}

" better navigation
Plug 'andymass/vim-matchup' "even better %. Navigate and highlight matching words
Plug 'junegunn/fzf', { 'dir': '~/.fzf', 'do': './install --all' } "Install fzf for user
Plug 'junegunn/fzf.vim'
Plug 'justinmk/vim-dirvish' "Directory viewer for Vim

" better vim
Plug 'tpope/vim-eunuch' "Helpers for UNIX - works nice with vim-dirvish
Plug 'junegunn/vim-slash' "Enhancing in-buffer search experience
Plug 'tpope/vim-sleuth' "Heuristically set buffer options
Plug 'skywind3000/asyncrun.vim' "Run Async Shell Commands in Vim 8.0 / NeoVim and Output to Quickfix Window
Plug 'machakann/vim-highlightedyank' "Make the yanked region apparent!
Plug 'christoomey/vim-sort-motion' "Vim mapping for sorting a range of text

" javascript
Plug 'leafgarland/typescript-vim', { 'for': 'typescript' }
Plug 'pangloss/vim-javascript', { 'for': 'javascript' }
Plug 'digitaltoad/vim-pug', {'for': 'jade'}
Plug 'evanleck/vim-svelte', {'for': 'svelte'}
Plug 'neoclide/coc.nvim', {'branch': 'release', 'for': ['javascript', 'typescript', 'scss', 'css', 'vue', 'svelte', 'scala']}

call plug#end()

let g:coc_global_extensions = [
			\ 'coc-json',
			\ 'coc-tsserver',
			\ 'coc-eslint',
			\ 'coc-snippets',
			\ 'coc-css',
			\ 'coc-vetur',
			\ 'coc-svelte',
			\ 'coc-metals'
			\ ]
